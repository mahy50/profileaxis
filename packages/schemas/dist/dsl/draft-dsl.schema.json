{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "draft-dsl.schema.json",
  "title": "DraftDsl",
  "description": "M1 frozen - structural draft and topology intent",
  "type": "object",
  "required": ["dslVersion", "modules"],
  "properties": {
    "dslVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["moduleId", "kind", "intent"],
        "properties": {
          "moduleId": { "type": "string" },
          "kind": { "type": "string", "const": "rect-bay" },
          "intent": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "additionalProperties": false
}
