{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "resolved-dsl.schema.json",
  "title": "ResolvedDsl",
  "description": "M1 frozen - Source of Truth. Accurate coordinates, specs, nodes, joints.",
  "type": "object",
  "required": ["dslVersion", "projectType", "sourceRevisionId", "overallSizeMm", "modules", "nodes", "joints"],
  "properties": {
    "dslVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "projectType": {
      "type": "string",
      "const": "storage_rack"
    },
    "sourceRevisionId": {
      "type": "string"
    },
    "overallSizeMm": {
      "type": "object",
      "required": ["width", "depth", "height"],
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "depth": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 }
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["moduleId", "kind", "spanMm"],
        "properties": {
          "moduleId": { "type": "string" },
          "kind": { "type": "string", "const": "rect-bay" },
          "spanMm": { "type": "number", "minimum": 1 }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/StructuralNode"
      }
    },
    "joints": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/JointNode"
      }
    }
  },
  "definitions": {
    "Vec3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "StructuralNode": {
      "type": "object",
      "required": ["nodeId", "kind", "role", "semanticPath", "axis", "start", "end", "lengthMm", "profileSpecKey", "provenance", "finishKey", "tags"],
      "properties": {
        "nodeId": { "type": "string" },
        "kind": { "type": "string", "enum": ["member", "module"] },
        "role": { "type": "string", "enum": ["upright", "beamX", "beamY", "brace", "foot"] },
        "semanticPath": { "type": "string" },
        "axis": { "type": "string", "enum": ["x", "y", "z"] },
        "start": { "$ref": "#/definitions/Vec3" },
        "end": { "$ref": "#/definitions/Vec3" },
        "lengthMm": { "type": "number", "minimum": 0 },
        "profileSpecKey": { "type": "string" },
        "provenance": {
          "type": "object",
          "required": ["source", "ruleIds"],
          "properties": {
            "source": { "type": "string", "enum": ["user", "ai", "rule", "system"] },
            "ruleIds": { "type": "array", "items": { "type": "string" } }
          }
        },
        "finishKey": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "JointNode": {
      "type": "object",
      "required": ["jointId", "topology", "semanticPath", "position", "memberIds", "connectorSpecKey", "connectorFamilyKey"],
      "properties": {
        "jointId": { "type": "string" },
        "topology": { "type": "string", "enum": ["corner-3way", "tee-3way", "cross-4way", "brace-end", "foot"] },
        "semanticPath": { "type": "string" },
        "position": { "$ref": "#/definitions/Vec3" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "connectorSpecKey": { "type": "string" },
        "connectorFamilyKey": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
