{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intent.schema.json",
  "title": "AI Intent Parsing I/O Schema",
  "description": "M1 frozen - AI intent parsing request/response",
  "type": "object",
  "oneOf": [
    { "$ref": "#/definitions/ParseRequirementsRequest" },
    { "$ref": "#/definitions/IntentResponse" }
  ],
  "definitions": {
    "ParseRequirementsRequest": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "enum": ["zh-CN", "en-US"] }
      },
      "additionalProperties": false
    },
    "IntentResponse": {
      "type": "object",
      "required": ["intentDsl", "needsConfirmationKeys"],
      "properties": {
        "intentDsl": { "$ref": "intent-dsl.schema.json" },
        "needsConfirmationKeys": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "AIResponse": {
      "oneOf": [
        {
          "type": "object",
          "required": ["status", "data"],
          "properties": {
            "status": { "type": "string", "const": "ok" },
            "data": { "type": "object" }
          }
        },
        {
          "type": "object",
          "required": ["status", "reason"],
          "properties": {
            "status": { "type": "string", "const": "refusal" },
            "reason": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["status", "message"],
          "properties": {
            "status": { "type": "string", "const": "schema_error" },
            "message": { "type": "string" },
            "schemaPath": { "type": "string" }
          }
        }
      ]
    }
  }
}
